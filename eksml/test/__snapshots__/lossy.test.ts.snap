// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`HTML mode > img with attributes 1`] = `
{
  "div": {
    "img": {
      "$alt": "photo",
      "$src": "x.png",
    },
    "span": "caption",
  },
}
`;

exports[`HTML mode > void elements self-close 1`] = `
{
  "div": {
    "br": null,
    "p": "text",
  },
}
`;

exports[`attributes > attributes prefixed with $ 1`] = `
{
  "div": {
    "$class": "wide",
    "$id": "main",
    "p": "text",
  },
}
`;

exports[`attributes > element with attributes and element-only children 1`] = `
{
  "root": {
    "$lang": "en",
    "a": "1",
    "b": "2",
  },
}
`;

exports[`attributes > null-valued attribute (boolean) 1`] = `
{
  "input": {
    "$disabled": null,
  },
}
`;

exports[`comments > comments are dropped by default 1`] = `
{
  "root": {
    "a": "1",
  },
}
`;

exports[`comments > comments kept when keepComments is true 1`] = `
{
  "root": {
    "$$": [
      "<!-- hello -->",
      {
        "a": "1",
      },
    ],
  },
}
`;

exports[`deep nesting > multiple levels 1`] = `
{
  "a": {
    "b": {
      "c": {
        "d": "deep",
      },
    },
  },
}
`;

exports[`edge cases > CDATA treated as text 1`] = `
{
  "root": "raw <text>",
}
`;

exports[`edge cases > attributes with empty string values 1`] = `
{
  "input": {
    "$value": "",
  },
}
`;

exports[`edge cases > element-only children with attributes on parent 1`] = `
{
  "root": {
    "$version": "2",
    "a": "x",
    "b": "y",
  },
}
`;

exports[`edge cases > empty root document 1`] = `
{
  "root": null,
}
`;

exports[`edge cases > mixed repeated elements with different complexity 1`] = `
{
  "root": {
    "x": [
      "simple",
      {
        "y": "nested",
      },
    ],
  },
}
`;

exports[`edge cases > repeated empty elements 1`] = `
{
  "root": {
    "br": [
      null,
      null,
      null,
    ],
  },
}
`;

exports[`empty elements > empty element with attributes becomes object with only $keys 1`] = `
{
  "root": {
    "img": {
      "$alt": "pic",
      "$src": "a.png",
    },
  },
}
`;

exports[`empty elements > empty open/close becomes null 1`] = `
{
  "root": {
    "empty": null,
  },
}
`;

exports[`empty elements > self-closing becomes null 1`] = `
{
  "root": {
    "br": null,
  },
}
`;

