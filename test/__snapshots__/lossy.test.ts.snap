  ",
      {
        "build": {
          "$$": [
            "
    ",
            {
              "plugins": {
                "$$": [
                  "
      ",
                  {
                    "plugin": {
                      "$$": [
                        "
        ",
                        {
                          "groupId": "org.springframework.boot",
                        },
                        "
        ",
                        {
                          "artifactId": "spring-boot-maven-plugin",
                        },
                        "
        ",
                        {
                          "version": "\${spring-boot.version}",
                        },
                        "
        ",
                        {
                          "configuration": {
                            "$$": [
                              "
          ",
                              {
                                "mainClass": "com.example.services.order.OrderServiceApplication",
                              },
                              "
          ",
                              {
                                "layers": {
                                  "$$": [
                                    "
            ",
                                    {
                                      "enabled": "true",
                                    },
                                    "
          ",
                                  ],
                                },
                              },
                              "
          ",
                              {
                                "image": {
                                  "$$": [
                                    "
            ",
                                    {
                                      "name": "ghcr.io/example/order-service:\${project.version}",
                                    },
                                    "
            ",
                                    {
                                      "env": {
                                        "$$": [
                                          "
              ",
                                          {
                                            "BP_JVM_VERSION": "\${java.version}",
                                          },
                                          "
            ",
                                        ],
                                      },
                                    },
                                    "
          ",
                                  ],
                                },
                              },
                              "
        ",
                            ],
                          },
                        },
                        "
        ",
                        {
                          "executions": {
                            "$$": [
                              "
          ",
                              {
                                "execution": {
                                  "$$": [
                                    "
            ",
                                    {
                                      "goals": {
                                        "$$": [
                                          "
              ",
                                          {
                                            "goal": "repackage",
                                          },
                                          "
              ",
                                          {
                                            "goal": "build-info",
                                          },
                                          "
            ",
                                        ],
                                      },
                                    },
                                    "
          ",
                                  ],
                                },
                              },
                              "
        ",
                            ],
                          },
                        },
                        "
      ",
                      ],
                    },
                  },
                  "
      ",
                  {
                    "plugin": {
                      "$$": [
                        "
        ",
                        {
                          "groupId": "org.apache.maven.plugins",
                        },
                        "
        ",
                        {
                          "artifactId": "maven-compiler-plugin",
                        },
                        "
        ",
                        {
                          "version": "3.13.0",
                        },
                        "
        ",
                        {
                          "configuration": {
                            "$$": [
                              "
          ",
                              {
                                "source": "\${java.version}",
                              },
                              "
          ",
                              {
                                "target": "\${java.version}",
                              },
                              "
          ",
                              {
                                "annotationProcessorPaths": {
                                  "$$": [
                                    "
            ",
                                    {
                                      "path": {
                                        "$$": [
                                          "
              ",
                                          {
                                            "groupId": "org.mapstruct",
                                          },
                                          "
              ",
                                          {
                                            "artifactId": "mapstruct-processor",
                                          },
                                          "
              ",
                                          {
                                            "version": "\${mapstruct.version}",
                                          },
                                          "
            ",
                                        ],
                                      },
                                    },
                                    "
            ",
                                    {
                                      "path": {
                                        "$$": [
                                          "
              ",
                                          {
                                            "groupId": "org.projectlombok",
                                          },
                                          "
              ",
                                          {
                                            "artifactId": "lombok",
                                          },
                                          "
              ",
                                          {
                                            "version": "\${lombok.version}",
                                          },
                                          "
            ",
                                        ],
                                      },
                                    },
                                    "
            ",
                                    {
                                      "path": {
                                        "$$": [
                                          "
              ",
                                          {
                                            "groupId": "org.projectlombok",
                                          },
                                          "
              ",
                                          {
                                            "artifactId": "lombok-mapstruct-binding",
                                          },
                                          "
              ",
                                          {
                                            "version": "0.2.0",
                                          },
                                          "
            ",
                                        ],
                                      },
                                    },
                                    "
          ",
                                  ],
                                },
                              },
                              "
          ",
                              {
                                "compilerArgs": {
                                  "$$": [
                                    "
            ",
                                    {
                                      "arg": "-Amapstruct.defaultComponentModel=spring",
                                    },
                                    "
            ",
                                    {
                                      "arg": "-Amapstruct.unmappedTargetPolicy=ERROR",
                                    },
                                    "
          ",
                                  ],
                                },
                              },
                              "
        ",
                            ],
                          },
                        },
                        "
      ",
                      ],
                    },
                  },
                  "
      ",
                  {
                    "plugin": {
                      "$$": [
                        "
        ",
                        {
                          "groupId": "org.jacoco",
                        },
                        "
        ",
                        {
                          "artifactId": "jacoco-maven-plugin",
                        },
                        "
        ",
                        {
                          "version": "\${jacoco.version}",
                        },
                        "
        ",
                        {
                          "executions": {
                            "$$": [
                              "
          ",
                              {
                                "execution": {
                                  "$$": [
                                    "
            ",
                                    {
                                      "id": "prepare-agent",
                                    },
                                    "
            ",
                                    {
                                      "goals": {
                                        "$$": [
                                          "
              ",
                                          {
                                            "goal": "prepare-agent",
                                          },
                                          "
            ",
                                        ],
                                      },
                                    },
                                    "
          ",
                                  ],
                                },
                              },
                              "
          ",
                              {
                                "execution": {
                                  "$$": [
                                    "
            ",
                                    {
                                      "id": "report",
                                    },
                                    "
            ",
                                    {
                                      "phase": "test",
                                    },
                                    "
            ",
                                    {
                                      "goals": {
                                        "$$": [
                                          "
              ",
                                          {
                                            "goal": "report",
                                          },
                                          "
            ",
                                        ],
                                      },
                                    },
                                    "
          ",
                                  ],
                                },
                              },
                              "
          ",
                              {
                                "execution": {
                                  "$$": [
                                    "
            ",
                                    {
                                      "id": "check",
                                    },
                                    "
            ",
                                    {
                                      "goals": {
                                        "$$": [
                                          "
              ",
                                          {
                                            "goal": "check",
                                          },
                                          "
            ",
                                        ],
                                      },
                                    },
                                    "
            ",
                                    {
                                      "configuration": {
                                        "$$": [
                                          "
              ",
                                          {
                                            "rules": {
                                              "$$": [
                                                "
                ",
                                                {
                                                  "rule": {
                                                    "$$": [
                                                      "
                  ",
                                                      {
                                                        "element": "BUNDLE",
                                                      },
                                                      "
                  ",
                                                      {
                                                        "limits": {
                                                          "$$": [
                                                            "
                    ",
                                                            {
                                                              "limit": {
                                                                "$$": [
                                                                  "
                      ",
                                                                  {
                                                                    "counter": "LINE",
                                                                  },
                                                                  "
                      ",
                                                                  {
                                                                    "value": "COVEREDRATIO",
                                                                  },
                                                                  "
                      ",
                                                                  {
                                                                    "minimum": "\${min.code.coverage}",
                                                                  },
                                                                  "
                    ",
                                                                ],
                                                              },
                                                            },
                                                            "
                    ",
                                                            {
                                                              "limit": {
                                                                "$$": [
                                                                  "
                      ",
                                                                  {
                                                                    "counter": "BRANCH",
                                                                  },
                                                                  "
                      ",
                                                                  {
                                                                    "value": "COVEREDRATIO",
                                                                  },
                                                                  "
                      ",
                                                                  {
                                                                    "minimum": "0.70",
                                                                  },
                                                                  "
                    ",
                                                                ],
                                                              },
                                                            },
                                                            "
                  ",
                                                          ],
                                                        },
                                                      },
                                                      "
                ",
                                                    ],
                                                  },
                                                },
                                                "
              ",
                                              ],
                                            },
                                          },
                                          "
            ",
                                        ],
                                      },
                                    },
                                    "
          ",
                                  ],
                                },
                              },
                              "
        ",
                            ],
                          },
                        },
                        "
      ",
                      ],
                    },
                  },
                  "
      ",
                  {
                    "plugin": {
                      "$$": [
                        "
        ",
                        {
                          "groupId": "org.apache.maven.plugins",
                        },
                        "
        ",
                        {
                          "artifactId": "maven-surefire-plugin",
                        },
                        "
        ",
                        {
                          "version": "3.2.5",
                        },
                        "
        ",
                        {
                          "configuration": {
                            "$$": [
                              "
          ",
                              {
                                "argLine": "@{argLine} --add-opens java.base/java.lang=ALL-UNNAMED",
                              },
                              "
          ",
                              {
                                "systemPropertyVariables": {
                                  "$$": [
                                    "
            ",
                                    {
                                      "spring.profiles.active": "test",
                                    },
                                    "
          ",
                                  ],
                                },
                              },
                              "
        ",
                            ],
                          },
                        },
                        "
      ",
                      ],
                    },
                  },
                  "
    ",
                ],
              },
            },
            "

    ",
            {
              "resources": {
                "$$": [
