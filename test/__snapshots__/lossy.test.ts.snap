            "
    ",
            {
              "image": {
                "$$": [
                  "
      ",
                  {
                    "url": "https://example.com/logo.png",
                  },
                  "
      ",
                  {
                    "title": "Tech Engineering Blog",
                  },
                  "
      ",
                  {
                    "link": "https://example.com/blog",
                  },
                  "
      ",
                  {
                    "width": "144",
                  },
                  "
