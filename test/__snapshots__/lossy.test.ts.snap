exports[`mixed content > nested mixed content 1`] = `
{
  "div": {
    "$$": [
      "before ",
      {
        "span": {
          "$$": [
            "inner ",
            {
              "b": "bold",
            },
            " after",
          ],
        },
      },
      " end",
    ],
  },
}
`;

exports[`mixed content > single text with attributes uses $$ array 1`] = `
{
  "a": {
    "$$": [
      "link text",
    ],
    "$href": "/",
  },
}
`;

exports[`processing instructions > xml declaration is filtered at top level 1`] = `
{
  "root": "text",
}
`;

