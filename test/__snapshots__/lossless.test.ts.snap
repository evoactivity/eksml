// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`CDATA > handles standalone CDATA 1`] = `
[
  {
    "$text": "data",
  },
]
`;

exports[`CDATA > represents CDATA as $text 1`] = `
[
  {
    "root": [
      {
        "$text": "hello <world>",
      },
    ],
  },
]
`;

exports[`HTML mode > handles raw content tags 1`] = `
[
  {
    "div": [
      {
        "script": [
          {
            "$text": "var x = 1 < 2;",
          },
        ],
      },
    ],
  },
]
`;

exports[`HTML mode > handles void elements 1`] = `
[
  {
    "div": [
      {
        "br": [],
      },
      {
        "hr": [],
      },
    ],
  },
]
`;

exports[`attributes > handles namespace attributes 1`] = `
[
  {
    "root": [
      {
        "$attr": {
          "xmlns:ns": "http://example.com",
        },
      },
      {
        "ns:elem": [
          {
            "$attr": {
              "ns:attr": "val",
            },
          },
        ],
      },
    ],
  },
]
`;

exports[`attributes > parses boolean attributes as null 1`] = `
[
  {
    "input": [
      {
        "$attr": {
          "checked": null,
          "disabled": null,
        },
      },
    ],
  },
]
`;

exports[`attributes > parses empty string attributes 1`] = `
[
  {
    "input": [
      {
        "$attr": {
          "value": "",
        },
      },
    ],
  },
]
`;

exports[`attributes > preserves attribute order 1`] = `
[
  {
    "el": [
      {
        "$attr": {
          "a": "1",
          "m": "2",
          "z": "3",
        },
      },
    ],
  },
]
`;

exports[`basic parsing > omits $attr entry when element has no attributes 1`] = `
[
  {
    "root": [
      {
        "child": [
          {
            "$text": "text",
          },
        ],
      },
    ],
  },
]
`;

exports[`basic parsing > parses a simple element 1`] = `
[
  {
    "test": [],
  },
]
`;

exports[`basic parsing > parses element with attributes 1`] = `
[
  {
    "test": [
      {
        "$attr": {
          "a": "1",
          "b": "2",
        },
      },
    ],
  },
]
`;

exports[`basic parsing > parses element with text child 1`] = `
[
  {
    "test": [
      {
        "$text": "hello",
      },
    ],
  },
]
`;

exports[`basic parsing > parses mixed content preserving order 1`] = `
[
  {
    "p": [
      {
        "$text": "Hello ",
      },
      {
        "b": [
          {
            "$text": "world",
          },
        ],
      },
      {
        "$text": "!",
      },
    ],
  },
]
`;

exports[`basic parsing > parses multiple children 1`] = `
[
  {
    "root": [
      {
        "a": [
          {
            "$text": "1",
          },
        ],
      },
      {
        "b": [
          {
            "$text": "2",
          },
        ],
      },
      {
        "c": [
          {
            "$text": "3",
          },
        ],
      },
    ],
  },
]
`;

exports[`basic parsing > parses nested elements 1`] = `
[
  {
    "a": [
      {
        "b": [
          {
            "c": [
              {
                "$text": "deep",
              },
            ],
          },
        ],
      },
    ],
  },
]
`;

exports[`basic parsing > parses self-closing elements 1`] = `
[
  {
    "root": [
      {
        "empty": [],
      },
    ],
  },
]
`;

exports[`basic parsing > parses text-only input 1`] = `
[
  {
    "$text": "just text",
  },
]
`;

exports[`basic parsing > puts attributes first, then children 1`] = `
[
  {
    "root": [
      {
        "$attr": {
          "id": "r",
        },
      },
      {
        "child": [
          {
            "$text": "text",
          },
        ],
      },
    ],
  },
]
`;

exports[`basic parsing > returns empty array for empty string 1`] = `[]`;

exports[`comments > preserves comments with keepComments 1`] = `
[
  {
    "root": [
      {
        "$comment": " hello ",
      },
      {
        "child": [],
      },
    ],
  },
]
`;

exports[`comments > preserves multiple comments 1`] = `
[
  {
    "root": [
      {
        "$comment": " first ",
      },
      {
        "$text": "text",
      },
      {
        "$comment": " second ",
      },
    ],
  },
]
`;

exports[`comments > strips comments by default 1`] = `
[
  {
    "root": [
      {
        "child": [],
      },
    ],
  },
]
`;

